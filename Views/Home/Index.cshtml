@{
    ViewData["Title"] = "Inicio";
}

<div class="container d-flex flex-column justify-content-center align-items-center vh-100">
    <div class="card bg-dark text-light shadow-lg text-center p-5">
        <h1 class="mb-3">Bienvenido a <span class="text-warning">Tafuka</span></h1>
        <h2 class="mb-4">App Administrativa</h2>

        <div class="d-flex flex-wrap justify-content-center">
            <a href="/Ventas" class="btn btn-vino m-2">📊 Ventas</a>
            <a href="/Gastos" class="btn btn-vino m-2">💸 Gastos</a>
            <a href="/CierresDiarios" class="btn btn-vino m-2">📆 Cierres Diarios</a>
            <a href="/CierresSemanales" class="btn btn-vino m-2">📅 Cierres Semanales</a>
            <a href="/Dashboard" class="btn btn-vino m-2">📈 Dashboard</a>
        </div>
    </div>
</div>

<style>
    .btn-vino {
        background-color: #5a0f1b; /* vino oscuro */
        color: #fff;
        border: none;
        padding: 15px 40px;
        font-size: 18px;
        border-radius: 8px;
        cursor: pointer;
        transition: 0.3s;
        text-decoration: none;
    }
    .btn-vino:hover {
        background-color: #7a1424; /* tono más claro al pasar el mouse */
        transform: scale(1.05);
    }
</style>
