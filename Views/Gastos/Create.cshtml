@model RestauranteApp.Models.Gasto

<div class="container mt-5">
    <div class="card bg-dark text-light shadow-lg">
        <div class="card-header text-center">
            <h2 class="mb-0">💸 Registrar Gasto</h2>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post" class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Fecha</label>
                    <input asp-for="Fecha" class="form-control bg-dark text-light border-secondary" type="date" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Monto</label>
                    <input asp-for="Monto" class="form-control bg-dark text-light border-secondary" type="number" step="0.01" />
                </div>
                <div class="col-12">
                    <label class="form-label">Descripción</label>
                    <input asp-for="Descripcion" class="form-control bg-dark text-light border-secondary" />
                </div>

                <div class="col-6 text-center mt-4">
                    <button type="submit" class="btn btn-lg btn-vino">
                        💾 Guardar
                    </button>
                </div>
                <div class="col-6 text-center mt-4">
                    <a href="/Home/Index" class="btn btn-lg btn-vino">
                        ⬅️ Volver al inicio
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .btn-vino {
        background-color: #5a0f1b; /* vino oscuro */
        color: #fff;
        border: none;
    }
    .btn-vino:hover {
        background-color: #7a1424; /* tono más claro */
        transform: scale(1.05);
    }
</style>
